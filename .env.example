# Google AI Studio (free tier: 100 RPD on Pro, 500+ RPD on Flash)
# Get from: https://aistudio.google.com/apikey
GOOGLE_AI_STUDIO_API_KEY=

# OpenRouter (free tier for DeepSeek V3.1 fallback)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Telegram bot
# 1. Message @BotFather on Telegram, send /newbot, follow prompts, copy token
# 2. Send one message to your bot
# 3. Visit https://api.telegram.org/bot<TOKEN>/getUpdates to find chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Dry-run mode: set to 1 to skip Telegram sends and LLM calls (useful for testing)
DRY_RUN=0
